   <string notr="true">/* 全局样式定义 */
QWidget#mainFrame {
	background-color: #ffffff;
	border-radius: 12px;
}

/* 标题栏 */
QLabel#lblTitle {
	font-size: 16px;
	font-weight: bold;
	color: #333333;
	padding: 10px;
}

/* 搜索框 */
QLineEdit {
	background-color: #f2f4f7;
	border: none;
	border-radius: 18px;
	padding: 10px 15px;
	font-size: 14px;
	color: #333333;
}
QLineEdit:focus {
	background-color: #ffffff;
	border: 1px solid #0086F6;
}

/* 树列表 */
QTreeWidget {
	border: none;
	background-color: transparent;
	color: #333333;
	font-size: 14px;
}
QTreeWidget::item {
	height: 44px;
	padding-left: 10px;
	border-bottom: 1px solid #f5f5f5;
}
QTreeWidget::item:hover {
	background-color: #f7f9fc;
}
QTreeWidget::item:selected {
	background-color: #eef6ff;
	color: #0086F6;
}

/* 滚动条美化 */
QScrollBar:vertical {
	border: none;
	background: transparent;
	width: 6px;
	margin: 0px;
}
QScrollBar::handle:vertical {
	background: #d0d0d0;
	min-height: 20px;
	border-radius: 3px;
}</string>
