  <property name="styleSheet">
   <string notr="true">/* 卡片背景 */
QWidget#Card {
	background-color: #ffffff;
	border-radius: 16px;
}
/* 通用字体 */
QLabel {
	font-family: &quot;Microsoft YaHei UI&quot;;
	color: #333333;
}
/* 输入框 */
QLineEdit {
	border: 1px solid #e0e0e0;
	border-radius: 8px;
	padding: 10px 15px;
	background-color: #f9fbfd;
	font-size: 14px;
	color: #333;
	selection-background-color: #0086F6;
}
QLineEdit:focus {
	border: 1px solid #0086F6;
	background-color: #ffffff;
}
/* 蓝色主按钮 */
QPushButton[class=&quot;primary&quot;] {
	background-color: #0086F6;
	color: white;
	border-radius: 8px;
	font-size: 16px;
	font-weight: bold;
	border: none;
}
QPushButton[class=&quot;primary&quot;]:hover { background-color: #0070d0; }
QPushButton[class=&quot;primary&quot;]:pressed { background-color: #005bb5; }

/* 文字按钮 */
QPushButton[class=&quot;textBtn&quot;] {
	background-color: transparent;
	color: #666666;
	border: none;
	font-size: 13px;
}
QPushButton[class=&quot;textBtn&quot;]:hover { color: #0086F6; text-decoration: underline; }

/* 关闭按钮 */
QPushButton#BtnClose {
	background-color: transparent;
	color: #aaaaaa;
	border: none;
	font-size: 20px;
	font-weight: bold;
}
QPushButton#BtnClose:hover { color: #FF4D4F; }</string>
